# ŠotoGO backend — copy this file to `.env` and fill in the values.

# HTTP port the API listens on.
PORT=3000

# Allowed frontend origin(s) for CORS — comma-separated, no trailing slash.
# Dev: http://localhost:5173 · Prod also add your Pages site, e.g.:
#   CLIENT_ORIGIN=https://tokancz.github.io,http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL connection string: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sotogo

# Postgres schema the tables live in (search_path is set per connection).
# Leave as `public` unless your host gives you a named schema.
DB_SCHEMA=public

# Secret used to sign JWTs. Use a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-only-change-me

# Google OAuth Client ID (the "Web application" client from Google Cloud Console).
# Leave blank to disable Google sign-in. See backend/README.md for the walkthrough.
GOOGLE_CLIENT_ID=

# In-app bug reporter → GitHub issues. Leave GITHUB_TOKEN blank to disable.
# GITHUB_TOKEN: a fine-grained Personal Access Token with "Issues: Read and write"
#   on the repo below. Create at https://github.com/settings/tokens?type=beta
# GITHUB_REPO: target repository as "owner/name".
GITHUB_TOKEN=
GITHUB_REPO=Tokancz/SotoGO
