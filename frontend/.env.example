# ŠotoGO frontend — copy to `.env.local` (gitignored) and fill in.

# Base URL of the backend API.
VITE_API_URL=http://localhost:3000/api

# Google OAuth Client ID (the SAME "Web application" client id as the backend's
# GOOGLE_CLIENT_ID). This one is public — it ships in the frontend bundle.
# Leave blank to hide/disable the Google sign-in button.
VITE_GOOGLE_CLIENT_ID=
